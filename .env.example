# Tier 2 only: API keys for rebuilding data from source
# Copy this file to .env and fill in your credentials

# Massive (https://massive.com) -- for SPXW option quotes
MASSIVE_API_KEY=your_massive_api_key_here

# ThetaData (https://thetadata.net) -- alternative data source
THETADATA_USER=your_email@example.com
THETADATA_PASS=your_password_here
