# 0DTE Replication Package — Environment Variables
# Copy this file to .env and fill in values as needed.

# ── Tier 2: API keys for raw data rebuild ──

# Massive API (https://massive.co)
# Used by: code/ingest/massive/download_spxw.py
MASSIVE_API_KEY=
# MASSIVE_BASE_URL=https://api.massive.com  # override if needed

# ThetaData API (https://thetadata.net)
# Used by: code/ingest/thetadata/download_spxw.py
# ThetaData uses a local Java terminal; these credentials configure it.
THETADATA_USERNAME=
THETADATA_PASSWORD=
# THETADATA_BASE_URL=http://127.0.0.1:25510  # local ThetaTerminal REST

# ── Optional overrides ──
# Override auto-detected repo root
# ODTE_REPO_ROOT=/path/to/0dte-strategies
